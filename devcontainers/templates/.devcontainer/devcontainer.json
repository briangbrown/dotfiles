{
  "name": "Isolated Work Environment (Fallback)",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:24",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  // Disable IPv6 so Claude Code's OAuth callback binds to IPv4,
  // which VS Code's port forwarding can actually reach.
  // See: https://github.com/anthropics/claude-code/issues/9376
  "runArgs": ["--sysctl", "net.ipv6.conf.all.disable_ipv6=1"],
  "containerEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code"
      ]
    }
  },
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code && git fetch",
  // The default image runs as "node" (non-root)
  "remoteUser": "node"
}
