# Shared environment variables — sourced by both bash and zsh

# Consistent 256-color support across all terminals
export TERM=xterm-256color

# --- Theme detection (light/dark) ---
# Priority: manual override > VS Code env > macOS system preference > default
# Use `theme light` or `theme dark` to switch mid-session.
if [ -z "$DOTFILES_THEME" ]; then
  if [ "$VSCODE_THEME_KIND" = "vscode-light" ] || [ "$VSCODE_THEME_KIND" = "vscode-high-contrast-light" ]; then
    export DOTFILES_THEME="light"
  elif [ "$VSCODE_THEME_KIND" = "vscode-dark" ] || [ "$VSCODE_THEME_KIND" = "vscode-high-contrast" ]; then
    export DOTFILES_THEME="dark"
  elif [ "$(uname)" = "Darwin" ] && ! defaults read -g AppleInterfaceStyle &>/dev/null 2>&1; then
    export DOTFILES_THEME="light"
  else
    export DOTFILES_THEME="dark"
  fi
fi

# Theme-aware tool defaults
if [ "$DOTFILES_THEME" = "light" ]; then
  export BAT_THEME="GitHub"
  export FZF_DEFAULT_OPTS="--color=light"
else
  export BAT_THEME="Dracula"
  export FZF_DEFAULT_OPTS="--color=dark"
fi

# fnm (Fast Node Manager) — macOS only, skipped in containers where Node
# is provided by the devcontainer image
if command -v fnm &>/dev/null; then
  eval "$(fnm env --use-on-cd)"
fi
